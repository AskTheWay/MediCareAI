.mt {
  margin-top: 16rpx;
}

.record-item {
  margin-top: 14rpx;
  border: 2rpx solid #dbe6f3;
  border-radius: 14rpx;
  padding: 16rpx;
  background: #fcfdff;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
}

.record-snippet {
  margin-top: 8rpx;
  color: #374151;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.detail-card {
  width: 100%;
  max-height: 88vh;
  overflow: auto;
  background: #fdfefe;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  box-sizing: border-box;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
}

.detail-text {
  white-space: pre-wrap;
  line-height: 1.6;
  color: #111827;
}

.comment-item {
  margin-top: 16rpx;
  padding: 14rpx;
  border: 2rpx solid #dbe6f3;
  border-radius: 12rpx;
  background: #ffffff;
}

.comment-title {
  font-weight: 600;
}

.reply-list {
  margin-top: 10rpx;
  padding: 10rpx;
  background: #f8fafc;
  border-radius: 10rpx;
}

.reply-item {
  margin-top: 10rpx;
}
