page {
  background: linear-gradient(180deg, #f1f6ff 0%, #f7fafc 38%, #f3f4f6 100%);
  color: #0f172a;
  font-size: 30rpx;
}

.container {
  padding: 24rpx 24rpx 44rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
}

.title {
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
}

.subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #64748b;
}

.helper {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 31rpx;
  font-weight: 650;
  margin-bottom: 14rpx;
  color: #1e293b;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #334155;
  font-size: 26rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  border: 2rpx solid #cbd5e1;
  border-radius: 14rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #0f172a;
  font-size: 28rpx;
  display: block;
}

.input {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 18rpx;
}

.picker {
  min-height: 84rpx;
  line-height: 84rpx;
  padding: 0 18rpx;
}

.textarea {
  min-height: 220rpx;
  line-height: 1.6;
  padding: 18rpx;
}

button::after {
  border: none;
}

.btn {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  margin-top: 16rpx;
  border-radius: 14rpx;
  font-weight: 600;
  font-size: 30rpx;
  line-height: 1.2;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.08);
}

.btn[disabled] {
  opacity: 0.65;
}

.btn-primary {
  background: linear-gradient(135deg, #0b5ed7 0%, #1d4ed8 100%);
  color: #ffffff;
}

.btn-secondary {
  background: #ffffff;
  color: #1d4ed8;
  border: 2rpx solid #93c5fd;
}

.btn-neutral {
  background: #f8fafc;
  color: #334155;
  border: 2rpx solid #cbd5e1;
}

.btn-mini {
  width: auto;
  min-width: 120rpx;
  height: 60rpx;
  line-height: 1.2;
  margin-top: 0;
  padding: 0 18rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow: none;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row > view,
.row > button {
  flex: 1;
}

.status {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.status-error {
  color: #b91c1c;
  background: #fef2f2;
  border: 2rpx solid #fecaca;
}

.status-info {
  color: #1d4ed8;
  background: #eff6ff;
  border: 2rpx solid #bfdbfe;
}

.status-success {
  color: #166534;
  background: #ecfdf3;
  border: 2rpx solid #bbf7d0;
}

.error {
  color: #b91c1c;
  margin-top: 12rpx;
  font-size: 24rpx;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}

.empty-tip {
  color: #64748b;
  font-size: 24rpx;
  text-align: center;
  padding: 24rpx 0 12rpx;
}

.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #dbeafe;
  color: #1d4ed8;
}
