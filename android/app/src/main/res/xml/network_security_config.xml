<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Config for Android 16 Development -->
<network-security-config>
    <!-- Debug configuration - allows all certificates for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user"/>
            <certificates src="system"/>
        </trust-anchors>
    </debug-overrides>
    
    <!-- Base configuration for all domains -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
    
    <!-- Specific configuration for openmedicareai.life -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">openmedicareai.life</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>
</network-security-config>