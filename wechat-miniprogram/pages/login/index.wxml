<view class="container">
  <view class="card auth-card">
    <view class="title">医疗智能助手</view>
    <view class="subtitle">患者登录</view>
    <view class="helper">登录后可提交症状、查看病历与管理个人健康档案。</view>

    <view class="field">
      <text class="label">邮箱</text>
      <input class="input" type="text" value="{{email}}" placeholder="请输入邮箱" bindinput="onEmailInput" />
    </view>

    <view class="field">
      <text class="label">密码</text>
      <input class="input" password="true" value="{{password}}" placeholder="请输入密码（至少6位）" bindinput="onPasswordInput" />
    </view>

    <view wx:if="{{error}}" class="status status-error">{{error}}</view>

    <button class="btn btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="onLogin">
      登录
    </button>

    <button class="btn btn-secondary" bindtap="goRegister">
      注册账号
    </button>
  </view>
</view>
