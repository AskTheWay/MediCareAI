<view class="container">
  <view class="card">
    <view class="title">患者资料</view>
    <view class="subtitle">编辑您的账号与健康档案</view>
    <view class="helper">资料保存后会同步到病历与问诊流程，建议保持信息准确。</view>

    <view class="field mt">
      <text class="label">邮箱</text>
      <input class="input" value="{{form.email}}" disabled="true" />
    </view>

    <view class="field">
      <text class="label">姓名</text>
      <input class="input" data-field="full_name" value="{{form.full_name}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">出生日期</text>
      <picker mode="date" value="{{form.date_of_birth}}" bindchange="onBirthDateChange">
        <view class="picker">{{form.date_of_birth || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <input class="input" data-field="phone" value="{{form.phone}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">地址</text>
      <textarea class="textarea" data-field="address" value="{{form.address}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">紧急联系人姓名</text>
      <input class="input" data-field="emergency_contact_name" value="{{form.emergency_contact_name}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">紧急联系人电话</text>
      <input class="input" data-field="emergency_contact_phone" value="{{form.emergency_contact_phone}}" bindinput="onInput" />
    </view>

    <view wx:if="{{error}}" class="status status-error">{{error}}</view>
    <view wx:if="{{success}}" class="status status-success">{{success}}</view>

    <button class="btn btn-primary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveProfile">保存资料</button>
  </view>

  <view class="card mt">
    <view class="section-title">慢病管理</view>

    <view wx:if="{{chronicDiseases.length === 0}}" class="empty-tip">暂无慢病记录，可在下方添加已确诊疾病。</view>

    <block wx:for="{{chronicDiseases}}" wx:key="id">
      <view class="disease-item">
        <view>
          <view class="disease-title">{{item._name}}</view>
          <view class="muted">{{item._severityLabel}} | {{item.diagnosis_date || '-'}}</view>
        </view>
        <button size="mini" class="btn-mini btn-neutral" data-id="{{item.id}}" bindtap="removeDisease">删除</button>
      </view>
    </block>

    <view class="section-title mt">添加疾病</view>

    <view class="field">
      <text class="label">疾病</text>
      <picker mode="selector" range="{{diseaseLabelOptions}}" value="{{diseaseIndex}}" bindchange="onDiseaseChange">
        <view class="picker">{{diseaseLabelOptions[diseaseIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">严重程度</text>
      <picker mode="selector" range="{{severityOptions}}" range-key="label" value="{{newDiseaseSeverityIndex}}" bindchange="onDiseaseSeverityChange">
        <view class="picker">{{severityOptions[newDiseaseSeverityIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">确诊日期</text>
      <picker mode="date" value="{{newDiseaseDate}}" bindchange="onDiseaseDateChange">
        <view class="picker">{{newDiseaseDate || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">备注</text>
      <textarea class="textarea" value="{{newDiseaseNotes}}" bindinput="onDiseaseNotesInput" />
    </view>

    <button class="btn btn-secondary" bindtap="addDisease">添加疾病</button>
  </view>
</view>
