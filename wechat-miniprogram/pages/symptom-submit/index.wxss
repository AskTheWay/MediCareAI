.mt {
  margin-top: 20rpx;
}

.file-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 2rpx solid #e2e8f0;
}

.file-row:last-child {
  border-bottom: none;
}

.file-name {
  font-weight: 600;
}

.doctor-option {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #e2e8f0;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.result-text {
  padding: 14rpx 16rpx;
  border: 2rpx solid #dbeafe;
  border-radius: 12rpx;
  background: #f8fbff;
  white-space: pre-wrap;
  line-height: 1.6;
}
