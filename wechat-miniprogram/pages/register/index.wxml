<view class="container">
  <view class="card">
    <view class="title">创建患者账号</view>
    <view class="subtitle">与网页端/安卓端共用同一后端</view>
    <view class="helper">请使用常用邮箱注册，后续找回密码和消息提醒会使用该邮箱。</view>

    <view class="field">
      <text class="label">姓名</text>
      <input class="input" data-field="full_name" value="{{form.full_name}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">邮箱</text>
      <input class="input" data-field="email" type="text" value="{{form.email}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">密码</text>
      <input class="input" data-field="password" password="true" value="{{form.password}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">确认密码</text>
      <input class="input" data-field="confirm_password" password="true" value="{{form.confirm_password}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">出生日期</text>
      <picker mode="date" value="{{form.date_of_birth}}" bindchange="onDateChange">
        <view class="picker">{{form.date_of_birth || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="picker">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <input class="input" data-field="phone" type="text" value="{{form.phone}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">地址</text>
      <textarea class="textarea" data-field="address" value="{{form.address}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">紧急联系人姓名</text>
      <input class="input" data-field="emergency_contact_name" value="{{form.emergency_contact_name}}" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">紧急联系人电话</text>
      <input class="input" data-field="emergency_contact_phone" value="{{form.emergency_contact_phone}}" bindinput="onInput" />
    </view>

    <view wx:if="{{error}}" class="status status-error">{{error}}</view>

    <button class="btn btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">
      注册
    </button>

    <button class="btn btn-secondary" bindtap="goLogin">
      返回登录
    </button>
  </view>
</view>
